# ─── DATABASE CONFIGURATION ──────────────────────────────────────────────────
# Supabase PostgreSQL connection strings
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/examedge?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/examedge?schema=public"

# ─── AUTH CONFIGURATION ──────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Hashed credentials password for bootstrapped admin account
# Generate with: node -e "console.log(require('bcryptjs').hashSync('YourSecureAdminPasswordHere', 10))"
ADMIN_PASSWORD_HASH="$2a$10$YourHashedBcryptPasswordHere"

# Social OAuth
GOOGLE_CLIENT_ID="google_client_id"
GOOGLE_CLIENT_SECRET="google_client_secret"
GITHUB_ID="github_id"
GITHUB_SECRET="github_secret"

# Resend Mailer API Key
RESEND_API_KEY="re_123456789"

# ─── CACHE & RATE LIMITING (UPSTASH REDIS) ──────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"

# ─── INSTANT SEARCH (ALGOLIA) ────────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID="ALGOLIA_APP_ID"
ALGOLIA_ADMIN_KEY="ALGOLIA_ADMIN_KEY"

# ─── FILE UPLOADS (UPLOADTHING) ──────────────────────────────────────────────
UPLOADTHING_SECRET="sk_live_uploadthing_secret"
UPLOADTHING_APP_ID="uploadthing_app_id"

# ─── VIDEO UPLOADS (CLOUDINARY) ──────────────────────────────────────────────
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ─── AI INTEGRATIONS (ANTHROPIC) ─────────────────────────────────────────────
# Claude 3.5 Sonnet API Key
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── ANALYTICS & MONITORING ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_posthog_client_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_SENTRY_DSN="https://example@o0.ingest.sentry.io/0"
