generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
  output          = "../client"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [vector(schema: "public")]
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String             @unique
  emailVerified DateTime?
  image         String?
  role          Role               @default(STUDENT)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  passwordHash  String?
  accounts      Account[]
  activityLogs  ActivityLog[]
  bookmarks     Bookmark[]
  roadmaps      GeneratedRoadmap[]
  predictions   SavedPrediction[]
  sessions      Session[]
  requests      StudentRequest[]
  profile       UserProfile?

  @@index([email])
  @@index([role])
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  university  String?
  year        Int?
  subjects    String[]
  examDate    DateTime?
  targetScore Int?
  bio         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subject {
  id          String           @id @default(cuid())
  name        String
  code        String           @unique
  description String?
  category    String
  thumbnail   String?
  isActive    Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  faqs        FAQ[]
  papers      Paper[]
  questions   Question[]
  requests    StudentRequest[]
  tags        Tag[]

  @@index([category])
  @@index([isActive])
}

model Tag {
  id        String     @id @default(cuid())
  name      String
  subjectId String?
  subject   Subject?   @relation(fields: [subjectId], references: [id])
  papers    Paper[]    @relation("PaperToTag")
  questions Question[] @relation("QuestionToTag")
}

model Paper {
  id            String     @id @default(cuid())
  title         String
  subjectId     String
  year          Int
  examType      ExamType
  university    String
  difficulty    Difficulty @default(MEDIUM)
  pdfUrl        String?
  pdfKey        String?
  videoUrl      String?
  thumbnailUrl  String?
  isPublished   Boolean    @default(false)
  downloadCount Int        @default(0)
  viewCount     Int        @default(0)
  algoliaId     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  createdBy     String
  bookmarks     Bookmark[]
  subject       Subject    @relation(fields: [subjectId], references: [id])
  solution      Solution?
  tags          Tag[]      @relation("PaperToTag")

  @@index([subjectId])
  @@index([year])
  @@index([examType])
  @@index([isPublished])
  @@index([university])
}

model Solution {
  id          String   @id @default(cuid())
  paperId     String   @unique
  content     String
  videoUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  paper       Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model Question {
  id             String                 @id @default(cuid())
  subjectId      String
  text           String
  topic          String
  chapter        String?
  type           QuestionType
  marks          Int
  importance     ImportanceLevel
  yearLastAsked  Int?
  modelAnswer    String?
  isPublished    Boolean                @default(false)
  predictedScore Float?
  embedding      Unsupported("vector")?
  algoliaId      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      String
  bookmarks      Bookmark[]
  subject        Subject                @relation(fields: [subjectId], references: [id])
  tags           Tag[]                  @relation("QuestionToTag")

  @@index([subjectId])
  @@index([importance])
  @@index([isPublished])
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String
  subjectId   String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  viewCount   Int      @default(0)
  helpful     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  subject     Subject? @relation(fields: [subjectId], references: [id])

  @@index([category])
  @@index([isPublished])
}

model Announcement {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      AnnouncementType @default(INFO)
  isActive  Boolean          @default(true)
  targetAll Boolean          @default(true)
  subjects  String[]
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  createdBy String

  @@index([isActive])
  @@index([expiresAt])
}

model StudentRequest {
  id         String        @id @default(cuid())
  userId     String
  subjectId  String?
  type       RequestType
  title      String
  message    String
  status     RequestStatus @default(PENDING)
  adminReply String?
  repliedAt  DateTime?
  repliedBy  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  subject    Subject?      @relation(fields: [subjectId], references: [id])
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Bookmark {
  id         String    @id @default(cuid())
  userId     String
  paperId    String?
  questionId String?
  createdAt  DateTime  @default(now())
  paper      Paper?    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, paperId])
  @@unique([userId, questionId])
  @@index([userId])
}

model GeneratedRoadmap {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  days      Int
  content   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedPrediction {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  examType  String
  content   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model PlatformStats {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  totalUsers     Int      @default(0)
  newUsers       Int      @default(0)
  paperViews     Int      @default(0)
  paperDownloads Int      @default(0)
  aiPredictions  Int      @default(0)
  aiRoadmaps     Int      @default(0)
  requestsNew    Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([date])
}

enum Role {
  STUDENT
  ADMIN
  SUPERADMIN
}

enum ExamType {
  MIDTERM
  FINAL
  COMPETITIVE
  MOCK
  ASSIGNMENT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  SHORT_ANSWER
  LONG_ANSWER
  MCQ
  NUMERICAL
  CASE_STUDY
}

enum ImportanceLevel {
  VERY_HIGH
  HIGH
  MEDIUM
  LOW
}

enum RequestType {
  PAPER_REQUEST
  SOLUTION_REQUEST
  TOPIC_CLARIFICATION
  BUG_REPORT
  FEATURE_REQUEST
  OTHER
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AnnouncementType {
  INFO
  WARNING
  IMPORTANT
  MAINTENANCE
}
